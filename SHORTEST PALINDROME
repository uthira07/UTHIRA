class Solution:
    def shortestPalindrome(self, s: str) -> str:
        if not s:
            return ""
        
        # 1. Create the combined string for KMP
        # format: original + separator + reversed
        combined = s + "#" + s[::-1]
        
        # 2. Compute the LPS (Longest Prefix Suffix) table
        n = len(combined)
        lps = [0] * n
        
        for i in range(1, n):
            j = lps[i - 1]
            while j > 0 and combined[i] != combined[j]:
                j = lps[j - 1]
            if combined[i] == combined[j]:
                j += 1
            lps[i] = j
            
        # 3. lps[-1] is the length of the longest palindromic prefix
        palindrome_len = lps[-1]
        
        # 4. Add the remaining suffix (reversed) to the front
        suffix_to_add = s[palindrome_len:][::-1]
        
        return suffix_to_add + s
