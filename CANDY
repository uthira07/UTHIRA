class Solution:
    def candy(self, ratings: List[int]) -> int:
        n = len(ratings)
        candies = [1] * n
        
        # 1. Left-to-Right Pass
        # Satisfy the condition: higher rating than left neighbor
        for i in range(1, n):
            if ratings[i] > ratings[i-1]:
                candies[i] = candies[i-1] + 1
        
        # 2. Right-to-Left Pass
        # Satisfy the condition: higher rating than right neighbor
        for i in range(n - 2, -1, -1):
            if ratings[i] > ratings[i+1]:
                # We take the max to ensure we don't break 
                # the left-neighbor condition established in step 1
                candies[i] = max(candies[i], candies[i+1] + 1)
        
        # 3. Sum up the results
        return sum(candies)
