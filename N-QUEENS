class Solution:
    def solveNQueens(self, n: int) -> List[List[str]]:
        col = set()
        posDiag = set() # (r + c)
        negDiag = set() # (r - c)
        
        res = []
        board = [["."] * n for _ in range(n)]

        def backtrack(r):
            # Base Case: All queens placed
            if r == n:
                copy = ["".join(row) for row in board]
                res.append(copy)
                return

            for c in range(n):
                # If the current position is under attack, skip it
                if c in col or (r + c) in posDiag or (r - c) in negDiag:
                    continue

                # 1. Action: Place the queen
                col.add(c)
                posDiag.add(r + c)
                negDiag.add(r - c)
                board[r][c] = "Q"

                # 2. Recursion: Move to the next row
                backtrack(r + 1)

                # 3. Backtrack: Remove the queen to try other paths
                col.remove(c)
                posDiag.remove(r + c)
                negDiag.remove(r - c)
                board[r][c] = "."

        backtrack(0)
        return res
