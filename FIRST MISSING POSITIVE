class Solution:
    def firstMissingPositive(self, nums: List[int]) -> int:
        n = len(nums)
        
        # 1. Place each number x at index x - 1 if possible
        for i in range(n):
            # Use a while loop to keep swapping until the current position
            # has the correct number or a number that doesn't belong
            while 1 <= nums[i] <= n and nums[nums[i] - 1] != nums[i]:
                # Swap nums[i] with the number at its target index
                target_idx = nums[i] - 1
                nums[i], nums[target_idx] = nums[target_idx], nums[i]
        
        # 2. Find the first index that doesn't match the value
        for i in range(n):
            if nums[i] != i + 1:
                return i + 1
        
        # 3. If all numbers from 1 to n are present, return n + 1
        return n + 1
